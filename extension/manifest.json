{
  "manifest_version": 3,
  "name": "Testudo Smart Search",
  "version": "1.0.0",
  "description": "Semantic natural-language course search for testudo.umd.edu",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background/service_worker.js"
  },
  "content_scripts": [
    {
      "matches": ["*://app.testudo.umd.edu/*"],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "http://localhost:8000/*"
  ],
  "permissions": [
    "storage"
  ]
}
